{
  "manifest_version": 3,
  "name": "PSOffice Analytics Dashboard",
  "version": "1.0",
  "description": "Dashboard analítico para Meu Resumo de Horas",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://psofficeapp.com.br/*"],
      "css": ["css/dashboard.css"],
      "js": [
        "libs/chart.js",
        "js/utils.js",
        "js/parser.js",
        "js/dashboard.js",
        "js/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}